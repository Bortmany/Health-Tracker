DATABASE_URL=postgres://user:password@localhost:5432/cut
DATABASE_SSL=false
JWT_SECRET=change-me
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Optional switches (features sleep until these are set)
# ANTHROPIC_API_KEY=   # wakes the AI plan writer
# STRIPE_SECRET_KEY=   # wakes paid Premium upgrades (needs all three + APP_URL)
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
# APP_URL=https://your-app.up.railway.app
# SENTRY_DSN=          # wakes error tracking (dormant until set; then run `npm install` so @sentry/node is present)
