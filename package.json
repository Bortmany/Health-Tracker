{
  "name": "cut",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c green,cyan \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "build": "npm run build -w apps/web",
    "migrate": "npm run migrate -w apps/api",
    "test": "npm run test -w apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
